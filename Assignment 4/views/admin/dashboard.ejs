<h1>Products Dashboard</h1>

<table class="products-table">

<tr>
    <th>Image</th>
    <th>Name</th>
    <th>Price</th>
    <th>Stock</th>
    <th>Category</th>
    <th>Actions</th>
</tr>

<% products.forEach(p => { %>

<tr>

    <td>
        <img class="product-image" src="/uploads/<%= p.image %>" width="50">
    </td>

    <td><%= p.name %></td>

    <td><%= p.price %></td>

    <td><%= p.stock %></td>

    <td><%= p.category %></td>

    <td>

        <a class="edit-btn" href="/admin/edit/<%= p._id %>">
            Edit
        </a>

        <a class="delete-btn"
           href="/admin/delete/<%= p._id %>"
           onclick="return confirm('Are you sure you want to delete this product?')">

           Delete

        </a>

    </td>

</tr>

<% }) %>

</table>