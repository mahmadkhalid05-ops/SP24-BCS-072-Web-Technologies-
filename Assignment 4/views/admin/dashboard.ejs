<h1>Products Dashboard</h1>

<table border="1">
<tr>
    <th>Image</th>
    <th>Name</th>
    <th>Price</th>
    <th>Stock</th>
    <th>Category</th>
    <th>Actions</th>
</tr>

<% products.forEach(p => { %>
<tr>
    <td><img src="/uploads/<%= p.image %>" width="50"></td>
    <td><%= p.name %></td>
    <td><%= p.price %></td>
    <td><%= p.stock %></td>
    <td><%= p.category %></td>
    <td>
        <a href="/admin/edit/<%= p._id %>">Edit</a>

        <a href="/admin/delete/<%= p._id %>" 
           onclick="return confirm('Are you sure you want to delete this product?')">
           Delete
        </a>
    </td>
</tr>
<% }) %>

</table>